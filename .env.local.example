# ════════════════════════════════════════════════════════════════════════════════
#  BankKey — variables d'environnement
#  Copier ce fichier en `.env.local` (jamais commité) et remplir les valeurs.
#  Sur Vercel : Settings → Environment Variables (mêmes clés).
#  Légende :  [REQUIS] indispensable · [OPTIONNEL] activable plus tard
# ════════════════════════════════════════════════════════════════════════════════

# ── IA — Anthropic ──────────────────────────────────────────────────── [REQUIS] ─
# https://console.anthropic.com/   (lue automatiquement par le SDK Anthropic)
ANTHROPIC_API_KEY=sk-ant-VOTRE_CLE

# ── Supabase ────────────────────────────────────────────────────────── [REQUIS] ─
# https://supabase.com → projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...      # Secret — jamais côté client

# ── App ─────────────────────────────────────────────────────────────── [REQUIS] ─
NEXT_PUBLIC_APP_URL=http://localhost:3000  # En prod : https://bankkey.ch

# ── Google OAuth (Gmail) ────────────────────────────────────────────── [REQUIS] ─
# https://console.cloud.google.com → Gmail API → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# URI de redirection à déclarer dans Google Cloud Console (prod = https://bankkey.ch/...)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# ── Stripe (abonnement Pro 199€) ────────────────────────────────────── [REQUIS] ─
# https://dashboard.stripe.com → Developers → API keys / Webhooks
STRIPE_SECRET_KEY=sk_live_ou_test_...
STRIPE_WEBHOOK_SECRET=whsec_...            # Endpoint /api/webhooks/stripe
STRIPE_PRICE_ID_PRO=price_...              # Prix récurrent 199€/mois

# ── Sécurité cron & webhooks ────────────────────────────────────────── [REQUIS] ─
# Secret partagé avec GitHub Actions (.github/workflows/cron.yml → secrets.CRON_SECRET).
# En production, son absence bloque les routes /api/cron/*.
CRON_SECRET=chaine_aleatoire_longue
# Secret du webhook email entrant (/api/ingest/email).
# En production, son absence fait répondre 503 (fail-closed).
WEBHOOK_INBOUND_SECRET=chaine_aleatoire_longue

# ── Email transactionnel — Resend ───────────────────────────────── [OPTIONNEL] ─
# Brief quotidien, digest mensuel, notification lead chaud, email de bienvenue.
# https://resend.com/api-keys   (domaine bankkey.ch à vérifier en DNS)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=BankKey <contact@bankkey.ch>
RESEND_REPLY_TO=contact@bankkey.ch

# ── Gmail temps réel (Pub/Sub push) ─────────────────────────────── [OPTIONNEL] ─
# Active l'ingestion < 1 min au lieu du polling cron. Voir lib/gmail.ts (watchInbox).
# Topic Pub/Sub Google Cloud (format : projects/<projet>/topics/<topic>)
GMAIL_PUBSUB_TOPIC=projects/VOTRE_PROJET/topics/gmail-leads
# Token partagé inclus dans l'URL de la souscription push :
#   https://bankkey.ch/api/gmail/push?token=<CE_TOKEN>
GMAIL_PUSH_TOKEN=chaine_aleatoire_longue

# ── Outlook / Microsoft 365 (ingestion) ─────────────────────────── [OPTIONNEL] ─
# Nécessite une app Azure (Microsoft Graph). Si absent, Outlook est désactivé.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Sentry (monitoring erreurs) ─────────────────────────────────── [OPTIONNEL] ─
# Si SENTRY_DSN absent, Sentry est désactivé (le build reste propre).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── Fournis automatiquement par Vercel — NE PAS définir à la main ────────────────
#   VERCEL_URL, VERCEL_ENV, NEXT_PUBLIC_VERCEL_ENV, NODE_ENV
