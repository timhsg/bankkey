      "schedule": "15 8 * * *"
    },
    {
      "path": "/api/cron/send-monthly-digest",
      "schedule": "0 9 1 * *"
    }
  ],
  "functions": {
    "app/api/cron/sync-gmail/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/send-daily-brief/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/send-monthly-digest/route.ts": {
      "maxDuration": 60
    },
    "app/api/gmail/process/route.ts": {
      "maxDuration": 60
    },
    "app/api/analyze/route.ts": {
      "maxDuration": 60
    }
  }
}
